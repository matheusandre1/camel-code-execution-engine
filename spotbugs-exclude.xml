<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude classes generated by annotation processors -->
    <Match>
        <Class name="~.*_Bean"/>
    </Match>
    <Match>
        <Class name="~.*_ClientProxy"/>
    </Match>
    <Match>
        <Class name="~.*_Subclass"/>
    </Match>
    <Match>
        <Class name="~.*_Observer.*"/>
    </Match>
</FindBugsFilter>
